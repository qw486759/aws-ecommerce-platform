# Terraform state and secrets — never commit these
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
.terraform/
.terraform.lock.hcl
# Terraform variable files may contain secrets
*.tfvars
*.tfvars.json

# AWS credentials and SSH keys
*.pem
*.csv
ecommerce-admin*

# Python
__pycache__/
*.pyc
.env

# OS
.DS_Store
Thumbs.db

overrides.json
ssm-policy.json
